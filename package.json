{
  "name": "signalwire-agents",
  "version": "0.1.0",
  "description": "SignalWire AI Agents SDK for TypeScript/Node.js",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "swaig-test": "./dist/cli/swaig-test.js"
  },
